DB_HOST=localhost
DB_PORT=5432
DB_NAME=meeting_db
DB_USER=postgres
DB_PASS=your_postgres_password_here

OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=qwen2.5:3b

WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_LANGUAGE=zh

EMBEDDING_MODEL=bge-m3

# Email (SMTP) — 用于发送会议纪要
# 注意：密码必须填写邮件服务商的"授权码"，不是登录密码
# 腾讯邮箱：SMTP_HOST=smtp.qq.com  SMTP_PORT=465  密码=QQ邮箱授权码
# 163邮箱：  SMTP_HOST=smtp.163.com SMTP_PORT=465  密码=163邮箱授权码（不支持587端口）
SMTP_HOST=smtp.163.com
SMTP_PORT=465
SMTP_USER=your_email@163.com
SMTP_PASSWORD=your_smtp_authorization_code_here
SMTP_FROM=your_email@163.com

# FunASR 模型目录（默认 ModelScope 缓存，无需修改；若需放到项目内请填绝对路径）
# 默认路径: C:\Users\<用户名>\.cache\modelscope\hub\models
# FUNASR_MODEL_DIR=D:\meeting_assistant\meeting-agent\storage\funasr_models
